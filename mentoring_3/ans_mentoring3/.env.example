SOURCE_DB_HOST=source_db
SOURCE_DB_PORT=5432
SOURCE_DB_NAME=source
SOURCE_DB_USER=postgres
SOURCE_DB_PASSWORD=postgres

WAREHOUSE_DB_HOST=data_warehouse
WAREHOUSE_DB_PORT=5432
WAREHOUSE_DB_NAME=data_warehouse
WAREHOUSE_DB_USER=postgres
WAREHOUSE_DB_PASSWORD=postgres

CSV_PATH=/app/data/new_bank_transactions.csv
JDBC_DRIVER_PATH=/opt/spark/jars/postgresql-42.6.0.jar
LOG_PATH=/app/logs/etl_pipeline.log
PROFILE_REPORT_PATH=/app/logs/latest_profile_summary.json

SPARK_APP_NAME=bank-etl-pipeline
SPARK_MASTER=local[4]
SPARK_DRIVER_MEMORY=1g
SPARK_SHUFFLE_PARTITIONS=8
MAX_VALID_YEAR=2025

DB_CONNECT_TIMEOUT_SECONDS=10
DB_SOCKET_TIMEOUT_SECONDS=60
RETRY_ATTEMPTS=3
RETRY_INITIAL_DELAY_SECONDS=2
RETRY_MAX_DELAY_SECONDS=15

SOURCE_DB_HOST_PORT=5438
WAREHOUSE_DB_HOST_PORT=5439
JUPYTER_HOST_PORT=8888
SPARK_UI_HOST_PORT=4040
SPARK_CONTAINER_MEMORY=2g
