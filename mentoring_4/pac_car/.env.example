SRC_POSTGRES_PASSWORD=admin

# Staging database
STG_POSTGRES_HOST=localhost
STG_POSTGRES_PORT=15436
STG_POSTGRES_DB=staging_db
STG_POSTGRES_USER=admin
STG_POSTGRES_PASSWORD=admin

# Warehouse database
WH_POSTGRES_HOST=localhost
WH_POSTGRES_PORT=15437
WH_POSTGRES_DB=warehouse_db
