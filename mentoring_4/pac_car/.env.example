# Spark and MLflow for local execution from host.
# Docker Compose overrides these values with service names.
SPARK_MASTER_URL=spark://localhost:17077
MLFLOW_TRACKING_URI=http://localhost:15000
MLFLOW_S3_ENDPOINT_URL=http://localhost:19004
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=admin1234

# Modeling
MODEL_TEST_SIZE=0.2
MODEL_RANDOM_SEED=42
